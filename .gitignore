# Node & Dependencies
node_modules/
client/node_modules/
server/node_modules/

# Environment Variables
.env
.env.local
.env.development
.env.production
*.pem

# Editor & Local Settings
.obsidian/
docs/.obsidian/

# Build Output & Compiled Files
# The CI/CD pipeline will generate these fresh every time
build/
dist/
client/build/
client/dist/
server/dist/
*.tsbuildinfo

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS & Editor Specific Files
.DS_Store
Thumbs.db
.vscode/
.idea/

# Testing & Coverage
coverage/
.nyc_output/

# Archives & Compressed Files
*.tar
*.tar.gz
*.tgz
*.gz
*.zip
*.rar

# Docker Local State & Volumes
# Ignore local volume mounts for databases
mongo-data/
db-data/
postgres-data/
# Ignore Docker desktop specific configs if generated locally
.docker/
# Local Docker Overrides
docker-compose.override.yml
docker-compose.local.yml

# Kubernetes & Helm
# Ignore local cluster credentials
kubeconfig
.kube/
# Ignore Helm build outputs (these are the .tgz files caught by the archive rule above)
charts/
*.tgz
# Ignore unencrypted local secret manifests
*secret*.yaml
*secret*.yml

# Framework & Platform State
.next/
.vercel/

# Kafka Local State
kafka-data/
zookeeper-data/
kraft-combined-logs/
kafka-secrets/